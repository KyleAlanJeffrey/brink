# RF-Nano MQTT bridge configuration.
# Installed to /etc/rfnano-bridge.env (mode 600, root only).
# After editing:  sudo systemctl restart rfnano-bridge

# Default: the broker runs on this Pi (see mosquitto/local.conf), so the bridge
# connects to localhost with no auth.
MQTT_HOST=localhost
MQTT_PORT=1883

# If the broker is elsewhere (or you add auth to Mosquitto), set these:
#MQTT_HOST=192.168.1.10
#MQTT_USER=homeassistant
#MQTT_PASS=change-me

# Optional overrides (uncomment to use):
#DISCOVERY_PREFIX=homeassistant
#SERIAL_PORT=/dev/ttyUSB0
#BAUD=115200
